# Modelo do Whisper (~1.6 GB) — baixar via /setup, nao versionar
models/*.bin

# Binarios da CLI do Tailwind (~100 MB cada) — baixar via /setup
web/tools/*

# Saidas geradas (timeline, preview, transcricao, analise)
output/*

# Cache do Python
__pycache__/
*.pyc

# Config local da maquina (nao deve ir para o repo publico)
.claude/settings.local.json

# Dependencias do Remotion (geradas por npm install)
remotion/node_modules/

# Build artifacts do Remotion
remotion/out/

# Build do frontend React
web/dist/

# Dependencias do frontend (geradas por npm install)
web/node_modules/

# Dependencias e build do exemplo Remotion (geradas por npm install)
remotion-example/node_modules/
remotion-example/out/

# Artefato antigo do Tailwind CLI (gerado; hoje o projeto usa @tailwindcss/vite)
web/tailwind.css

# Arquivo lixo (redirecionamento acidental para o device 'nul' do Windows)
/nul
